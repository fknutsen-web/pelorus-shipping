# Supabase — create a project at https://supabase.com, then copy these from
# Project Settings → API. The SERVICE_ROLE key is secret: server-side only.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# Optional: email notifications on new lead/engagement (e.g. Resend). Leave blank to skip.
# RESEND_API_KEY=
# LEAD_NOTIFY_TO=contact@pelorusshipping.com

# Stripe — for the $500 refundable engagement deposit (Phase 2).
# Secret key: server-side only. Webhook secret: from the Stripe dashboard endpoint
# pointed at /api/stripe-webhook. Leave blank to disable the deposit step.
# STRIPE_SECRET_KEY=sk_live_or_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
