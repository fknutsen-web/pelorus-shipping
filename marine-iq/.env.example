# Supabase project (create at https://supabase.com, then apply supabase/migrations in order)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only. Used by admin server actions (user approval, moderation, audit logging).
# NEVER expose this to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Base URL of the deployed app (used in auth email redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Optional integrations (every feature degrades gracefully when unset) ---

# AI summaries of reviews (claude-haiku-4-5). Without a key, a deterministic
# template summary is generated from the weighted category scores instead.
ANTHROPIC_API_KEY=

# Payments: ad campaigns, subscriptions, marketplace, featured jobs.
# Without a key, orders are recorded as pending_payment for manual follow-up.
STRIPE_SECRET_KEY=

# Email notifications & digests via Resend (in-app notifications always work).
RESEND_API_KEY=
EMAIL_FROM="Marine IQ <notifications@yourdomain.com>"

# Protects /api/cron/digest (schedule with Vercel Cron or similar)
CRON_SECRET=
